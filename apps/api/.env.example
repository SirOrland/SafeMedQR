# Copy this file to .env and fill in your Neon (Vercel Postgres) connection string
# cp .env.example .env
#
# Find your DATABASE_URL in:
# Vercel Dashboard → Storage → your Postgres DB → .env.local tab → POSTGRES_URL
# or Neon Dashboard → your project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
